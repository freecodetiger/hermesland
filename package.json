{
  "name": "hermesland",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "server/*"
  ],
  "scripts": {
    "test": "node --test",
    "test:protocol": "npm --workspace @hermesland/hermes-protocol test",
    "test:gateway": "npm --workspace @hermesland/gateway test",
    "smoke": "node scripts/smoke.mjs",
    "smoke:strict:local": "node scripts/strict-smoke-local.mjs",
    "test:swift-sdk": "cd packages/hermes-swift-sdk && swift test",
    "typecheck:macos-source": "swiftc -typecheck apps/macos/Sources/AppShell/*.swift apps/macos/Sources/UIState/*.swift"
  },
  "engines": {
    "node": ">=22"
  }
}
