{
  "name": "hermesland",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "hermesland",
      "version": "0.1.0",
      "workspaces": [
        "packages/*",
        "server/*"
      ],
      "engines": {
        "node": ">=22"
      }
    },
    "node_modules/@hermesland/gateway": {
      "resolved": "server/gateway",
      "link": true
    },
    "node_modules/@hermesland/hermes-protocol": {
      "resolved": "packages/hermes-protocol",
      "link": true
    },
    "packages/hermes-protocol": {
      "name": "@hermesland/hermes-protocol",
      "version": "0.1.0"
    },
    "server/gateway": {
      "name": "@hermesland/gateway",
      "version": "0.1.0"
    }
  }
}
